# ============================================
# Required Environment Variables
# ============================================
S3_BUCKET=your-s3-bucket             # S3 bucket name for file storage
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-secret-key-here      # JWT signing key for authentication

# ============================================
# Optional - Server Configuration
# ============================================
# HOST=0.0.0.0                        # Server host binding
# PORT=8000                           # Server port
# DEBUG=false                         # Enable Starlette debug mode
# RELOAD=false                        # Enable auto-reload on file changes
# LOG_LEVEL=INFO                      # Logging level (DEBUG, INFO, WARNING, ERROR)

# ============================================
# Optional - Processing Configuration
# ============================================
# MAX_CONCURRENT_FILES=5              # Max files to process in parallel
# TRANSLATION_BATCH_SIZE=20           # Cells/paragraphs per Bedrock API call
# MAX_FILE_SIZE=52428800              # Max upload file size in bytes (50MB)

# ============================================
# Optional - CORS Configuration
# ============================================
# FRONTEND_URL=http://localhost:3000  # Frontend URL for CORS

# ============================================
# Optional - AWS Configuration
# ============================================
# Note: AWS credentials are typically provided via:
# - IAM instance role (EC2/ECS)
# - AWS CLI configuration (~/.aws/credentials)
# - Environment variables (uncomment below if needed)
#
# AWS_DEFAULT_REGION=us-west-2
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
